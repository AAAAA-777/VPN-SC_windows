<ui:FluentWindow x:Class="VpnSc.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:conv="clr-namespace:VpnSc.Converters"
        Title="VPN Security Connect"
        WindowStartupLocation="Manual"
        ResizeMode="NoResize"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        Background="{StaticResource VpnPageBackgroundBrush}">

    <Grid x:Name="RootGrid">
        <Grid Margin="0,32,0,0">

            <!-- LOADING -->
            <Grid Visibility="{Binding CurrentPage, Converter={StaticResource PageVis}, ConverterParameter=Loading}"
                  Style="{StaticResource VpnPageRoot}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ui:ProgressRing IsIndeterminate="True" Width="48" Height="48"/>
                    <TextBlock Text="{Binding LoadingText}" Style="{StaticResource VpnBodyText}"
                               Margin="0,16,0,0" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <!-- NO INTERNET -->
            <Grid Visibility="{Binding CurrentPage, Converter={StaticResource PageVis}, ConverterParameter=NoInternet}"
                  Style="{StaticResource VpnPageRoot}" Margin="16">
                <ui:Card VerticalAlignment="Center" Padding="24">
                    <StackPanel HorizontalAlignment="Center" MaxWidth="280">
                        <Border Style="{StaticResource VpnIconBadge}" HorizontalAlignment="Center" Margin="0,0,0,16">
                            <ui:SymbolIcon Symbol="WifiOff24" FontSize="22"
                                           Foreground="{StaticResource VpnDangerBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{Binding NoInternetTitle}" Style="{StaticResource VpnCardTitle}"/>
                        <TextBlock Text="{Binding NoInternetMessage}" Style="{StaticResource VpnBodyText}"
                                   TextAlignment="Center" Margin="0,10,0,0"/>
                        <ui:Button Appearance="Primary" Content="{Binding RetryText}" Margin="0,20,0,0"
                                   Command="{Binding RetryInternetCommand}" HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </ui:Card>
            </Grid>

            <!-- BLOCKED -->
            <Grid Visibility="{Binding CurrentPage, Converter={StaticResource PageVis}, ConverterParameter=Blocked}"
                  Style="{StaticResource VpnPageRoot}" Margin="16">
                <ui:Card VerticalAlignment="Center" Padding="24">
                    <StackPanel HorizontalAlignment="Center" MaxWidth="280">
                        <Border Style="{StaticResource VpnIconBadge}" HorizontalAlignment="Center" Margin="0,0,0,16">
                            <ui:SymbolIcon Symbol="Warning24" FontSize="22"
                                           Foreground="{StaticResource VpnDangerBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{Binding BlockedTitle}" Style="{StaticResource VpnCardTitle}"/>
                        <TextBlock Text="{Binding BlockedMessage}" Style="{StaticResource VpnBodyText}"
                                   TextAlignment="Center" Margin="0,10,0,0"/>
                        <ui:Button Appearance="Primary" Content="{Binding UpdateAppButtonText}" Margin="0,20,0,0"
                                   Command="{Binding UpdateAppCommand}" HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </ui:Card>
            </Grid>

            <!-- LOGIN -->
            <Grid Visibility="{Binding CurrentPage, Converter={StaticResource PageVis}, ConverterParameter=Login}"
                  Style="{StaticResource VpnPageRoot}">
                <ScrollViewer Padding="16" VerticalScrollBarVisibility="Auto">
                <ui:Card VerticalAlignment="Center" Padding="24" Margin="0,8">
                    <StackPanel>
                        <Border Style="{StaticResource VpnIconBadge}" Width="56" Height="56" CornerRadius="28"
                                HorizontalAlignment="Center" Background="{StaticResource VpnConnectBrush}">
                            <ui:SymbolIcon Symbol="Shield24" FontSize="26" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{Binding AppName}" FontSize="24" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,16,0,4"/>
                        <TextBlock Text="{Binding AppTagline}" Style="{StaticResource VpnBodyText}"
                                   HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,20"/>
                        <TextBlock Text="{Binding LoginTitleText}" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,6"/>
                        <TextBlock Text="{Binding LoginDescriptionText}" Style="{StaticResource VpnBodyText}" Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding LoginSubdescriptionText}" FontSize="12"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                   TextWrapping="Wrap" Margin="0,0,0,16"/>
                        <TextBlock Text="{Binding EmailLabelText}" FontSize="13" FontWeight="Medium"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,6"/>
                        <ui:TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="email@example.com"/>
                        <ui:Button Appearance="Primary" Content="{Binding GetCodeText}" Margin="0,16,0,0"
                                   Command="{Binding GetCodeCommand}" HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </ui:Card>
                </ScrollViewer>
            </Grid>

            <!-- VERIFY -->
            <Grid Visibility="{Binding CurrentPage, Converter={StaticResource PageVis}, ConverterParameter=Verify}"
                  Style="{StaticResource VpnPageRoot}">
                <ScrollViewer Padding="16" VerticalScrollBarVisibility="Auto">
                <ui:Card VerticalAlignment="Center" Padding="24" Margin="0,8">
                    <StackPanel>
                        <Border Style="{StaticResource VpnIconBadge}" Width="56" Height="56" CornerRadius="28"
                                HorizontalAlignment="Center" Background="{StaticResource VpnConnectBrush}">
                            <ui:SymbolIcon Symbol="Mail24" FontSize="26" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{Binding VerifyTitleText}" FontSize="22" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,16,0,6"/>
                        <TextBlock Text="{Binding VerifySubtitleText}" Style="{StaticResource VpnBodyText}"
                                   HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,20"/>
                        <TextBlock Text="{Binding CodeHintText}" FontSize="13" FontWeight="Medium"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,6"/>
                        <ui:TextBox Text="{Binding Code, UpdateSourceTrigger=PropertyChanged}"
                                    FontSize="22" FontWeight="SemiBold" MaxLength="6"
                                    HorizontalContentAlignment="Center"/>
                        <ui:Button Appearance="Primary" Content="{Binding VerifyBtnText}" Margin="0,16,0,0"
                                   Command="{Binding VerifyCommand}" HorizontalAlignment="Stretch"/>
                        <ui:Button Appearance="Transparent" Content="{Binding ResendButtonText}" Margin="0,8,0,0"
                                   Command="{Binding ResendCommand}" IsEnabled="{Binding CanResendCode}"
                                   HorizontalAlignment="Stretch"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                            <TextBlock Text="{Binding NoCodeReceivedText}" FontSize="12"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" VerticalAlignment="Center"/>
                            <ui:Button Appearance="Transparent" Content="{Binding ChangeEmailText}" Margin="4,0,0,0"
                                        Command="{Binding ChangeEmailCommand}" Padding="4,0"/>
                        </StackPanel>
                    </StackPanel>
                </ui:Card>
                </ScrollViewer>
            </Grid>

            <!-- SUB BLOCKED -->
            <Grid Visibility="{Binding CurrentPage, Converter={StaticResource PageVis}, ConverterParameter=SubBlocked}"
                  Style="{StaticResource VpnPageRoot}" Margin="16">
                <ui:Card VerticalAlignment="Center" Padding="24">
                    <StackPanel HorizontalAlignment="Center" MaxWidth="280">
                        <Border Style="{StaticResource VpnIconBadge}" HorizontalAlignment="Center" Margin="0,0,0,16">
                            <ui:SymbolIcon Symbol="LockClosed24" FontSize="22"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{Binding SubBlockedTitle}" Style="{StaticResource VpnCardTitle}"/>
                        <TextBlock Text="{Binding SubBlockedMessage}" Style="{StaticResource VpnBodyText}"
                                   TextAlignment="Center" Margin="0,10,0,0"/>
                        <ui:Button Appearance="Primary" Content="{Binding SubscribeButtonText}" Margin="0,20,0,0"
                                   Command="{Binding SubscribeCommand}" HorizontalAlignment="Stretch"/>
                        <ui:Button Appearance="Secondary" Content="{Binding CheckSubscriptionButtonText}" Margin="0,8,0,0"
                                   Command="{Binding CheckSubscriptionCommand}" HorizontalAlignment="Stretch"/>
                        <ui:Button Appearance="Transparent" Content="{Binding LogoutText}" Margin="0,8,0,0"
                                    Command="{Binding LogoutCommand}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </ui:Card>
            </Grid>

            <!-- MAIN VPN -->
            <Grid Visibility="{Binding CurrentPage, Converter={StaticResource PageVis}, ConverterParameter=Main}"
                  Style="{StaticResource VpnPageRoot}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource VpnWpfUiToolbar}">
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <ui:SymbolIcon Symbol="Shield24" FontSize="18" Foreground="{StaticResource VpnConnectBrush}" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding AppName}" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <ui:Button Appearance="Transparent" ToolTip="{Binding SettingsTooltip}"
                                       Command="{Binding OpenSettingsCommand}" Width="34" Height="34" Padding="0">
                                <ui:SymbolIcon Symbol="Settings24" FontSize="16"/>
                            </ui:Button>
                            <ui:Button Appearance="Transparent" ToolTip="{Binding ProfileTooltip}"
                                       Command="{Binding OpenProfileCommand}" Width="34" Height="34" Padding="0" Margin="2,0,0,0">
                                <ui:SymbolIcon Symbol="Person24" FontSize="16"/>
                            </ui:Button>
                            <ui:Button Appearance="Transparent" ToolTip="{Binding LogoutTooltip}"
                                       Command="{Binding LogoutCommand}" Width="34" Height="34" Padding="0" Margin="2,0,0,0">
                                <ui:SymbolIcon Symbol="SignOut24" FontSize="16"/>
                            </ui:Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16,12">
                    <StackPanel>
                        <!-- Status (без белой карточки в отключённом состоянии — как Flutter) -->
                        <Border Padding="20" Margin="0,0,0,16" Background="Transparent" BorderThickness="0">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding VpnConnected}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource LayerFillColorDefaultBrush}"/>
                                            <Setter Property="CornerRadius" Value="8"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel HorizontalAlignment="Center">
                                <Grid Width="72" Height="72" HorizontalAlignment="Center">
                                    <Border Width="72" Height="72" CornerRadius="36"
                                            Background="{DynamicResource ControlFillColorDefaultBrush}">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding VpnConnected}" Value="True">
                                                        <Setter Property="Background" Value="#1A107C10"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <ui:SymbolIcon Symbol="Power24" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <ui:SymbolIcon.Style>
                                                <Style TargetType="ui:SymbolIcon">
                                                    <Setter Property="Foreground" Value="{StaticResource VpnConnectBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding VpnConnected}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource VpnSuccessBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsConnecting}" Value="True">
                                                            <Setter Property="Opacity" Value="0.35"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ui:SymbolIcon.Style>
                                        </ui:SymbolIcon>
                                    </Border>
                                    <ui:ProgressRing Width="72" Height="72" IsIndeterminate="True"
                                                     Foreground="{StaticResource VpnConnectBrush}"
                                                     Visibility="{Binding IsConnecting, Converter={StaticResource BoolVis}}"/>
                                </Grid>
                                <TextBlock Text="{Binding ConnectionStatusText}" FontSize="15" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                           HorizontalAlignment="Center" Margin="0,12,0,0"/>
                                <TextBlock Text="{Binding ConnectedServerLabel}" Style="{StaticResource VpnBodyText}"
                                           HorizontalAlignment="Center" Margin="0,4,0,0"
                                           Visibility="{Binding ConnectedServerLabel, Converter={StaticResource StringVis}}"/>
                            </StackPanel>
                        </Border>

                        <!-- Server -->
                        <TextBlock Text="{Binding SelectServerText}" Style="{StaticResource VpnSectionTitle}"/>
                        <ui:Card Margin="0,0,0,8" Padding="10"
                                 Visibility="{Binding ServersEmpty, Converter={StaticResource BoolVis}}">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Warning24" FontSize="16" Foreground="#FF9A3412" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding ServersNotFoundText}" FontSize="12" Foreground="#FF9A3412"
                                           TextWrapping="Wrap" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ui:Card>
                        <ui:Card Padding="0">
                            <Button Background="Transparent" BorderThickness="0" Cursor="Arrow"
                                    Command="{Binding OpenServerSelectionCommand}"
                                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch" MinHeight="48" Padding="12,10">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="Transparent" Padding="{TemplateBinding Padding}"
                                                MinHeight="{TemplateBinding MinHeight}">
                                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid Grid.Column="0" Width="32" Height="24" VerticalAlignment="Center" Margin="0,0,10,0">
                                        <ui:SymbolIcon Symbol="Globe24" FontSize="16"
                                                       Foreground="{StaticResource VpnConnectBrush}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Visibility="{Binding ServerIsSmartLocation, Converter={StaticResource BoolVis}}"/>
                                        <Image Source="{Binding ServerFlagImage}" Width="28" Height="20" Stretch="Uniform"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Visibility="{Binding ServerFlagImage, Converter={StaticResource NullVis}}"/>
                                    </Grid>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,8,0">
                                        <TextBlock Text="{Binding PickerServerName}" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding ProtocolValueText}" FontSize="12"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,2,0,0"
                                                   Visibility="{Binding SelectedServer, Converter={StaticResource StringVis}}"/>
                                    </StackPanel>
                                    <ui:SymbolIcon Grid.Column="2" Symbol="ChevronDown24" FontSize="14"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   VerticalAlignment="Center"/>
                                </Grid>
                            </Button>
                        </ui:Card>

                        <!-- Connect -->
                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ui:Button Grid.Column="0" Appearance="Primary"
                                       Command="{Binding ConnectVpnCommand}"
                                       Content="{Binding ConnectButtonText}"
                                       HorizontalAlignment="Stretch"/>
                            <ui:Button Grid.Column="2" Appearance="Secondary" Content="{Binding DisconnectButtonText}"
                                       Command="{Binding DisconnectVpnCommand}"
                                       IsEnabled="{Binding VpnConnected}"
                                       HorizontalAlignment="Stretch"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>

                <!-- Таймер и трафик — внизу окна -->
                <Border Grid.Row="2" Padding="16,12" Background="Transparent" BorderThickness="0"
                        Visibility="{Binding ShowConnectionDetails, Converter={StaticResource BoolVis}}">
                    <StackPanel>
                        <!-- Таймер подключения (временно скрыт)
                        <TextBlock Text="{Binding ConnectionDurationText}" FontSize="32" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   HorizontalAlignment="Center"/>
                        -->
                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding TrafficUplinkText}"
                                       HorizontalAlignment="Center"
                                       Style="{StaticResource VpnBodyText}" FontWeight="Medium"/>
                            <TextBlock Grid.Column="1" Text="{Binding TrafficDownlinkText}"
                                       HorizontalAlignment="Center"
                                       Style="{StaticResource VpnBodyText}" FontWeight="Medium"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- SERVER SELECTION -->
            <Grid Visibility="{Binding CurrentPage, Converter={StaticResource PageVis}, ConverterParameter=ServerSelection}"
                  Style="{StaticResource VpnPageRoot}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Style="{StaticResource VpnWpfUiToolbar}">
                    <Grid Height="36">
                        <ui:Button HorizontalAlignment="Left" Appearance="Transparent"
                                   Command="{Binding GoBackCommand}" ToolTip="{Binding BackText}"
                                   Width="34" Height="34" Padding="0" Panel.ZIndex="10">
                            <ui:SymbolIcon Symbol="ChevronLeft24" FontSize="16"/>
                        </ui:Button>
                        <TextBlock Text="{Binding PageTitle}" Style="{StaticResource VpnPageTitle}"/>
                    </Grid>
                </Border>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16,10">
                    <ItemsControl ItemsSource="{Binding ServerItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ui:Card Margin="0,0,0,6" Padding="0">
                                    <Button Background="Transparent" BorderThickness="0" Cursor="Arrow"
                                            Command="{Binding DataContext.SelectServerCommand, ElementName=RootGrid}"
                                            CommandParameter="{Binding}" HorizontalContentAlignment="Stretch" Padding="10,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid Grid.Column="0" Width="20" Margin="0,0,8,0" VerticalAlignment="Center">
                                                <ui:SymbolIcon Symbol="ChevronRight24" FontSize="14"
                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <ui:SymbolIcon.Style>
                                                        <Style TargetType="ui:SymbolIcon">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </ui:SymbolIcon.Style>
                                                </ui:SymbolIcon>
                                                <ui:SymbolIcon Symbol="Checkmark24" FontSize="16"
                                                               Foreground="{StaticResource VpnConnectBrush}"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               Visibility="{Binding IsSelected, Converter={StaticResource BoolVis}}"/>
                                            </Grid>
                                            <Grid Grid.Column="1" Width="36" Height="28" VerticalAlignment="Center" Margin="0,0,10,0">
                                                <ui:SymbolIcon Symbol="Globe24" FontSize="16"
                                                               Foreground="{StaticResource VpnConnectBrush}"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               Visibility="{Binding IsSmartLocation, Converter={StaticResource BoolVis}}"/>
                                                <Image Source="{Binding FlagImage}" Width="26" Height="18" Stretch="Uniform"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Visibility="{Binding FlagImage, Converter={StaticResource NullVis}}"/>
                                            </Grid>
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                <TextBlock Text="{Binding Subtitle}" FontSize="11" Margin="0,2,0,0"
                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                            </StackPanel>
                                            <Border Grid.Column="3" Background="#FFEFF6FF" CornerRadius="6" Padding="6,3"
                                                    VerticalAlignment="Center"
                                                    Visibility="{Binding ShowRecommended, Converter={StaticResource BoolVis}}">
                                                <TextBlock Text="{Binding RecommendedText}" FontSize="10" FontWeight="Medium"
                                                           Foreground="{StaticResource VpnConnectBrush}"/>
                                            </Border>
                                        </Grid>
                                    </Button>
                                </ui:Card>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- SETTINGS -->
            <Grid Visibility="{Binding CurrentPage, Converter={StaticResource PageVis}, ConverterParameter=Settings}"
                  Style="{StaticResource VpnPageRoot}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Style="{StaticResource VpnWpfUiToolbar}">
                    <Grid Height="36">
                        <ui:Button HorizontalAlignment="Left" Appearance="Transparent"
                                   Command="{Binding GoBackCommand}" ToolTip="{Binding BackText}"
                                   Width="34" Height="34" Padding="0" Panel.ZIndex="10">
                            <ui:SymbolIcon Symbol="ChevronLeft24" FontSize="16"/>
                        </ui:Button>
                        <TextBlock Text="{Binding PageTitle}" Style="{StaticResource VpnPageTitle}"/>
                    </Grid>
                </Border>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16,10">
                    <StackPanel>
                        <ui:Card Margin="0,0,0,8" Padding="14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource VpnIconBadge}">
                                    <ui:SymbolIcon Symbol="Rocket24" FontSize="18"
                                                   Foreground="{StaticResource VpnConnectBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="12,0,10,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding AutostartTitleText}" Style="{StaticResource VpnSettingsRowTitle}"/>
                                    <TextBlock Text="{Binding AutostartSubText}" Style="{StaticResource VpnSettingsRowSub}"/>
                                </StackPanel>
                                <ui:ToggleSwitch Grid.Column="2" IsChecked="{Binding AutostartEnabled}" VerticalAlignment="Center"/>
                            </Grid>
                        </ui:Card>

                        <ui:Card Margin="0,0,0,8" Padding="14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource VpnIconBadge}">
                                    <ui:SymbolIcon Symbol="Shield24" FontSize="18"
                                                   Foreground="{StaticResource VpnSuccessBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="12,0,10,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding ProtocolTitleText}" Style="{StaticResource VpnSettingsRowTitle}"/>
                                    <TextBlock Text="{Binding ProtocolSubText}" Style="{StaticResource VpnSettingsRowSub}"/>
                                </StackPanel>
                                <ComboBox Grid.Column="2" Width="140" SelectedIndex="{Binding ProtocolIndex}"
                                          ItemsSource="{Binding ProtocolOptions}" VerticalAlignment="Center"/>
                            </Grid>
                        </ui:Card>

                        <ui:Card Margin="0,0,0,8" Padding="14"
                                   Visibility="{Binding ShowFragmentationSetting, Converter={StaticResource BoolVis}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource VpnIconBadge}">
                                    <ui:SymbolIcon Symbol="Shield24" FontSize="18"
                                                   Foreground="{StaticResource VpnSuccessBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="12,0,10,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding FragmentationTitleText}" Style="{StaticResource VpnSettingsRowTitle}"/>
                                    <TextBlock Text="{Binding FragmentationSubText}" Style="{StaticResource VpnSettingsRowSub}"/>
                                </StackPanel>
                                <ui:ToggleSwitch Grid.Column="2" IsChecked="{Binding FragmentationEnabled}" VerticalAlignment="Center"/>
                            </Grid>
                        </ui:Card>

                        <ui:Card Margin="0,0,0,8" Padding="14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource VpnIconBadge}">
                                    <ui:SymbolIcon Symbol="Globe24" FontSize="18"
                                                   Foreground="{StaticResource VpnConnectBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="12,0,10,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding LanguageTitleText}" Style="{StaticResource VpnSettingsRowTitle}"/>
                                    <TextBlock Text="{Binding LanguageSubText}" Style="{StaticResource VpnSettingsRowSub}"/>
                                </StackPanel>
                                <ComboBox Grid.Column="2" Width="100" SelectedIndex="{Binding LanguageIndex}"
                                          ItemsSource="{Binding LanguageOptions}" VerticalAlignment="Center"/>
                            </Grid>
                        </ui:Card>

                        <ui:Card Margin="0,0,0,8" Padding="12"
                                 Visibility="{Binding UpdateBannerVisible, Converter={StaticResource BoolVis}}">
                            <StackPanel>
                                <TextBlock Text="{Binding UpdateBannerText}" FontWeight="SemiBold"
                                           Foreground="{StaticResource VpnConnectBrush}" TextWrapping="Wrap"/>
                                <ui:Button Appearance="Secondary" Content="{Binding CheckUpdatesText}" Margin="0,10,0,0"
                                           Command="{Binding CheckUpdatesCommand}" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </ui:Card>

                        <ui:Card Padding="14">
                            <StackPanel>
                                <TextBlock Text="{Binding AppInfoTitleText}" Style="{StaticResource VpnSettingsRowTitle}" Margin="0,0,0,8"/>
                                <TextBlock Text="{Binding VersionInfoText}" Style="{StaticResource VpnBodyText}" Margin="0,2,0,0"/>
                                <TextBlock Text="{Binding InfoProtocolText}" Style="{StaticResource VpnBodyText}" Margin="0,2,0,0"/>
                                <TextBlock Text="{Binding InfoAutostartText}" Style="{StaticResource VpnBodyText}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </ui:Card>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- PROFILE -->
            <Grid Visibility="{Binding CurrentPage, Converter={StaticResource PageVis}, ConverterParameter=Profile}"
                  Style="{StaticResource VpnPageRoot}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Style="{StaticResource VpnWpfUiToolbar}">
                    <Grid Height="36">
                        <ui:Button HorizontalAlignment="Left" Appearance="Transparent"
                                   Command="{Binding GoBackCommand}" ToolTip="{Binding BackText}"
                                   Width="34" Height="34" Padding="0" Panel.ZIndex="10">
                            <ui:SymbolIcon Symbol="ChevronLeft24" FontSize="16"/>
                        </ui:Button>
                        <TextBlock Text="{Binding PageTitle}" Style="{StaticResource VpnPageTitle}"/>
                    </Grid>
                </Border>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16,10">
                    <StackPanel>
                        <ui:Card Padding="20" Margin="0,0,0,12">
                            <StackPanel HorizontalAlignment="Center">
                                <Border Width="64" Height="64" CornerRadius="32" HorizontalAlignment="Center"
                                        Background="{StaticResource VpnConnectBrush}" Margin="0,0,0,12">
                                    <ui:SymbolIcon Symbol="Person24" FontSize="28" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="{Binding ProfileEmail}" FontSize="16" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" HorizontalAlignment="Center"/>
                                <Border Background="#FFEFF6FF" CornerRadius="6" Padding="8,4" Margin="0,10,0,0"
                                        HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding ProfileVerifiedText}" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource VpnSuccessBrush}"/>
                                </Border>
                                <TextBlock Text="{Binding ProfileSubscriptionText}" Style="{StaticResource VpnBodyText}"
                                           HorizontalAlignment="Center" Margin="0,10,0,0"/>
                            </StackPanel>
                        </ui:Card>
                        <ui:Button Appearance="Primary" Content="{Binding DeviceManagementText}"
                                   Command="{Binding OpenSessionsCommand}" HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- SESSIONS -->
            <Grid Visibility="{Binding CurrentPage, Converter={StaticResource PageVis}, ConverterParameter=Sessions}"
                  Style="{StaticResource VpnPageRoot}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Style="{StaticResource VpnWpfUiToolbar}">
                    <Grid Height="36">
                        <ui:Button HorizontalAlignment="Left" Appearance="Transparent"
                                   Command="{Binding GoBackCommand}" ToolTip="{Binding BackText}"
                                   Width="34" Height="34" Padding="0" Panel.ZIndex="10">
                            <ui:SymbolIcon Symbol="ChevronLeft24" FontSize="16"/>
                        </ui:Button>
                        <TextBlock Text="{Binding PageTitle}" Style="{StaticResource VpnPageTitle}"/>
                    </Grid>
                </Border>
                <ui:Card Grid.Row="1" Margin="16,10,16,0" Padding="4">
                    <ListBox ItemsSource="{Binding SessionItems}" SelectedItem="{Binding SelectedSession}"
                             Style="{StaticResource VpnSessionListBox}" DisplayMemberPath="Display"/>
                </ui:Card>
                <ui:Button Grid.Row="2" Margin="16,10,16,14" Appearance="Danger"
                           Content="{Binding TerminateSessionText}" Command="{Binding TerminateSessionCommand}"
                           HorizontalAlignment="Stretch"/>
            </Grid>

        </Grid>

        <ui:TitleBar x:Name="AppTitleBar"
                     Panel.ZIndex="10"
                     Height="32"
                     Padding="0"
                     VerticalAlignment="Top"
                     Title="VPN Security Connect"
                     FontSize="12"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                     ShowMinimize="True" ShowMaximize="True" CanMaximize="False" ShowClose="True"/>
    </Grid>
</ui:FluentWindow>
