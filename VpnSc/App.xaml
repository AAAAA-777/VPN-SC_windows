<Application x:Class="VpnSc.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:conv="clr-namespace:VpnSc.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Light" />
                <ui:ControlsDictionary />
                <ResourceDictionary Source="Themes/VpnBranding.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <conv:PageVisibilityConverter x:Key="PageVis"/>
            <conv:InverseBooleanConverter x:Key="InvBool"/>
            <BooleanToVisibilityConverter x:Key="BoolVis"/>
            <conv:StringNotEmptyToVisibilityConverter x:Key="StringVis"/>
            <conv:NullToVisibilityConverter x:Key="NullVis"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
