<Window x:Class="VpnSc.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Settings"
        Width="420" Height="520"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource VpnPageBackgroundBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
        <StackPanel>
            <TextBlock x:Name="TxtTitle" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>

            <ui:Card Padding="14" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock x:Name="TxtAutostartTitle" Style="{StaticResource VpnSettingsRowTitle}"/>
                    <TextBlock x:Name="TxtAutostartSub" Style="{StaticResource VpnSettingsRowSub}" Margin="0,2,0,8"/>
                    <ui:ToggleSwitch x:Name="ChkAutostart"/>
                </StackPanel>
            </ui:Card>

            <ui:Card Padding="14" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock x:Name="TxtProtocolTitle" Style="{StaticResource VpnSettingsRowTitle}"/>
                    <TextBlock x:Name="TxtProtocolSub" Style="{StaticResource VpnSettingsRowSub}" Margin="0,2,0,8"/>
                    <TextBlock x:Name="TxtProtocolValue" FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource VpnConnectBrush}"/>
                </StackPanel>
            </ui:Card>

            <ui:Card Padding="14" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock x:Name="TxtLangTitle" Style="{StaticResource VpnSettingsRowTitle}"/>
                    <TextBlock x:Name="TxtLangSub" Style="{StaticResource VpnSettingsRowSub}" Margin="0,2,0,8"/>
                    <ComboBox x:Name="LangCombo"/>
                </StackPanel>
            </ui:Card>

            <ui:Card x:Name="UpdateBanner" Padding="14" Margin="0,0,0,8" Visibility="Collapsed">
                <StackPanel>
                    <TextBlock x:Name="TxtUpdateAvailable" FontWeight="SemiBold"
                               Foreground="{StaticResource VpnConnectBrush}"/>
                    <ui:Button x:Name="BtnUpdate" Appearance="Primary" Margin="0,10,0,0"
                               HorizontalAlignment="Left" Click="BtnUpdate_OnClick"/>
                </StackPanel>
            </ui:Card>

            <ui:Card Padding="14">
                <StackPanel>
                    <TextBlock x:Name="TxtInfoTitle" Style="{StaticResource VpnSettingsRowTitle}" Margin="0,0,0,8"/>
                    <TextBlock x:Name="TxtVersion" Style="{StaticResource VpnBodyText}"/>
                    <TextBlock x:Name="TxtInfoProtocol" Style="{StaticResource VpnBodyText}" Margin="0,2,0,0"/>
                    <TextBlock x:Name="TxtInfoAutostart" Style="{StaticResource VpnBodyText}" Margin="0,2,0,0"/>
                </StackPanel>
            </ui:Card>
        </StackPanel>
    </ScrollViewer>
</Window>
